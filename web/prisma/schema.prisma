datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model Vulnerability {
  id          String    @id @default(cuid())
  filePath    String
  line        Int
  column      Int
  endLine     Int
  endColumn   Int
  codeSnippet String
  codeHash    String

  type            String
  cweId           String?
  severity        String
  description     String
  riskDescription String?

  fixOldCode     String?
  fixNewCode     String?
  fixExplanation String?

  aiModel      String?
  aiConfidence Float?
  aiReasoning  String?

  humanStatus     String    @default("pending")
  humanComment    String?
  humanReviewedAt DateTime?
  owaspCategory   String?

  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([filePath, line, column, codeHash, type], name: "vuln_idempotent")
  @@index([status])
  @@index([severity])
  @@index([filePath])
  @@map("vulnerabilities")
}

model ScanTask {
  id           String   @id @default(cuid())
  status       String   @default("pending")
  progress     Float    @default(0)
  totalFiles   Int      @default(0)
  scannedFiles Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("scan_tasks")
}

/// 單列配置表（singleton），id 固定為 "default"
model Config {
  id        String   @id @default("default")
  data      String   // JSON 序列化的 PluginConfig
  updatedAt DateTime @updatedAt

  @@map("configs")
}
