datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model Vulnerability {
  id          String    @id @default(cuid())
  filePath    String
  line        Int
  column      Int
  endLine     Int
  endColumn   Int
  codeSnippet String
  codeHash    String

  type            String
  cweId           String?
  severity        String
  description     String
  riskDescription String?

  fixOldCode     String?
  fixNewCode     String?
  fixExplanation String?

  aiModel      String?
  aiConfidence Float?
  aiReasoning  String?

  humanStatus     String    @default("pending")
  humanComment    String?
  humanReviewedAt DateTime?
  owaspCategory   String?

  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events VulnerabilityEvent[]

  @@unique([filePath, line, column, codeHash, type], name: "vuln_idempotent")
  @@index([status])
  @@index([severity])
  @@index([filePath])
  @@map("vulnerabilities")
}

model VulnerabilityEvent {
  id              String   @id @default(cuid())
  vulnerabilityId String
  eventType       String
  message         String
  fromStatus      String?
  toStatus        String?
  fromHumanStatus String?
  toHumanStatus   String?
  createdAt       DateTime @default(now())

  vulnerability Vulnerability @relation(fields: [vulnerabilityId], references: [id], onDelete: Cascade)

  @@index([vulnerabilityId, createdAt(sort: Desc)])
  @@map("vulnerability_events")
}

model ScanTask {
  id           String   @id @default(cuid())
  status       String   @default("pending")
  engineMode   String   @default("baseline")
  progress     Float    @default(0)
  totalFiles   Int      @default(0)
  scannedFiles Int      @default(0)
  fallbackUsed Boolean  @default(false)
  fallbackFrom String?
  fallbackTo   String?
  fallbackReason String?
  errorMessage String?
  errorCode    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([engineMode, updatedAt(sort: Desc)])
  @@map("scan_tasks")
}

model AdviceSnapshot {
  id                 String   @id @default(cuid())
  summary            String
  confidence         Float
  triggerScore       Float
  triggerReason      String
  sourceEvent        String
  metricsFingerprint String
  actionItems        String
  rawResponse        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  decisions AdviceDecision[]

  @@index([createdAt(sort: Desc)])
  @@map("advice_snapshots")
}

model AdviceDecision {
  id                    String   @id @default(cuid())
  sourceEvent           String
  sourceTaskId          String?
  sourceVulnerabilityId String?
  triggerScore          Float
  triggerReason         String
  metricsFingerprint    String
  shouldCallAi          Boolean  @default(false)
  calledAi              Boolean  @default(false)
  blockedReason         String?
  llmError              String?
  metricSnapshot        String
  adviceSnapshotId      String?
  createdAt             DateTime @default(now())

  adviceSnapshot AdviceSnapshot? @relation(fields: [adviceSnapshotId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([calledAi, createdAt(sort: Desc)])
  @@index([sourceEvent, createdAt(sort: Desc)])
  @@map("advice_decisions")
}

/// 單列配置表（singleton），id 固定為 "default"
model Config {
  id        String   @id @default("default")
  data      String   // JSON 序列化的 PluginConfig
  updatedAt DateTime @updatedAt

  @@map("configs")
}
